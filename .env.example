# Copy this to .env and fill in values
MODEL_DIR=models
DATASET_DIR=datasets
DEFAULT_MODEL_NAME=tfidf_logreg
CORS_ORIGINS=["http://localhost:3000"]

# Dataset column mapping defaults (override per-request in POST /train body)
DATASET_TEXT_COLUMN=text
DATASET_LABEL_COLUMN=label
DATASET_LABEL_POSITIVE_VALUE=spam
